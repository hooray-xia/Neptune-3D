		<script type>
			window.addEventListener('DOMContentLoaded', function() {
				var jn = document.getElementById('join-nickname')
				var jl = document.getElementById('join-langs')
				var jr = document.getElementById('join-reason')
				var jp = document.getElementById('join-project')
				var jrole = document.getElementById('join-role')
				var jout = document.getElementById('text')
				var jgen = document.getElementById('join-generate')
				var jcopy = document.getElementById('join-copy')
				var jmsg = document.getElementById('join-msg')
				if (jcopy) {
					jcopy.disabled = true
				}

				function isValidUrl(u) {
					if (!u) return false;
					var s = u.trim().toLowerCase();
					return s.startsWith('http') && s.indexOf('khanacademy.org') !== -1
				}

				function mark(el, ok) {
					if (!el) return;
					el.classList[ok ? 'remove' : 'add']('join-invalid')
				}

				function updateFilled(el) {
					if (!el) return;
					el.classList[el.value.trim().length > 0 ? 'add' : 'remove']('join-filled')
				}

				function notify(msg) {
					try {
						window.alert(msg)
					} catch (e) {}
				}

				function animateButtonState(button, className, duration) {
					if (!button) return
					button.classList.remove(className)
					void button.offsetWidth
					button.classList.add(className)
					if (duration) {
						window.setTimeout(function() {
							button.classList.remove(className)
						}, duration)
					}
				}

				function allValid() {
					var n = jn && jn.value.trim().length > 0
					var l = jl && jl.value.trim().length > 0
					var r = jr && jr.value.trim().length > 0
					var p = jp && isValidUrl(jp.value)
					var ro = jrole && jrole.value.trim().length > 0
					mark(jn, n);
					mark(jl, l);
					mark(jr, r);
					mark(jp, p);
					mark(jrole, ro)
					if (jmsg) {
						jmsg.textContent = (n && l && r && p && ro) ? "" : "Fill all fields and use a Khan Academy project link"
					}
					return n && l && r && p && ro
				}

				function gen(show) {
					updateFilled(jn)
					updateFilled(jl)
					updateFilled(jr)
					updateFilled(jp)
					updateFilled(jrole)
					var t = 'Application Template\n\n' +
						'Nickname: ' + (jn ? jn.value.trim() : '') + '\n\n' +
						'Primary languages/tools: ' + (jl ? jl.value.trim() : '') + '\n\n' +
						'Reason for joining:\n' + (jr ? jr.value.trim() : '') + '\n\n' +
						'Link to your best project: ' + (jp ? jp.value.trim() : '') + '\n\n' +
						'Role interest: ' + (jrole ? jrole.value.trim() : '')
					if (jout) {
						jout.textContent = t
					}
					if (show && jout) {
						var sp = (typeof showPanel === 'function')
						if (sp) {
							showPanel('join')
						}
						jout.classList.add('show')
						try {
							jout.scrollIntoView({
								behavior: 'smooth',
								block: 'center'
							})
						} catch (e) {}
					}
					var txt = jout ? jout.textContent.trim() : ''
					if (jcopy) {
						if (txt.length > 0) {
							jcopy.disabled = false
						} else {
							jcopy.disabled = true
						}
					}
					if (show && jgen) {
						animateButtonState(jgen, 'generated', 1800)
					}
				}

				function copyText() {
					var el = document.getElementById('text')
					var t = el && el.innerText ? el.innerText.trim() : ''
					if (t.length === 0) {
						notify('Nothing to copy')
						throw new Error('copy failed')
					}

					function success() {
						try {
							animateButtonState(jcopy, 'copied', 1800)
							notify('Copied to clipboard!')
						} catch (e) {}
					}

					function fail() {
						notify('Copy failed')
						throw new Error('copy failed')
					}
					var copyArea = document.getElementById('hidden')
					if (!copyArea) {
						fail();
