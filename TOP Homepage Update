						'https://upload.wikimedia.org/wikipedia/commons/b/b7/Chthonianplanet.jpg?utm_source=commons.wikimedia.org&utm_campaign=index&utm_content=original',

						'https://upload.wikimedia.org/wikipedia/commons/a/a1/Artist%E2%80%99s_impression_of_Proxima_d_%28wider_view%29.jpg?utm_source=commons.wikimedia.org&utm_campaign=index&utm_content=original',
						'https://upload.wikimedia.org/wikipedia/commons/5/51/Proxima_Centauri_b_%2829196109016%29.png?utm_source=commons.wikimedia.org&utm_campaign=index&utm_content=original',
						'https://upload.wikimedia.org/wikipedia/commons/6/67/Artist%E2%80%99s_impression_of_Proxima_d_%28close-up%29.jpg?utm_source=commons.wikimedia.org&utm_campaign=index&utm_content=original',
					],
					'Gas Giants': [
						'https://upload.wikimedia.org/wikipedia/commons/e/ec/Ammonia_clouds_gas_giant.jpg?utm_source=commons.wikimedia.org&utm_campaign=index&utm_content=original',
						'https://upload.wikimedia.org/wikipedia/commons/7/71/Class-v_cubicapoc.png?utm_source=commons.wikimedia.org&utm_campaign=index&utm_content=original',
						'https://upload.wikimedia.org/wikipedia/commons/a/ae/Gasgiant.jpg?utm_source=commons.wikimedia.org&utm_campaign=index&utm_content=original',
						'https://upload.wikimedia.org/wikipedia/commons/9/95/Blue_Ringed_Gas_Giant_%2813879196965%29.png?utm_source=commons.wikimedia.org&utm_campaign=index&utm_content=original',
						'https://upload.wikimedia.org/wikipedia/commons/e/ed/Jupiter-like_planet_with_a_red_dwarf_star.jpg?utm_source=commons.wikimedia.org&utm_campaign=index&utm_content=original',
						'https://upload.wikimedia.org/wikipedia/commons/c/cd/Artist%27s_rendering_of_a_Neptune-type_exoplanet.jpg?utm_source=commons.wikimedia.org&utm_campaign=index&utm_content=original',
					],
					'Stars and Nebula': [
						'https://upload.wikimedia.org/wikipedia/commons/e/ed/Jupiter-like_planet_with_a_red_dwarf_star.jpg?utm_source=commons.wikimedia.org&utm_campaign=index&utm_content=original',
						'https://upload.wikimedia.org/wikipedia/commons/b/b3/Artist_impression_of_ultra_fluffy_gas_giant_planet_orbiting_a_red_dwarf_star.jpg?utm_source=commons.wikimedia.org&utm_campaign=index&utm_content=original',
						'https://upload.wikimedia.org/wikipedia/commons/b/bf/Black_Hole_Outflows_From_Centaurus_A.jpg?utm_source=commons.wikimedia.org&utm_campaign=index&utm_content=original',
						'https://upload.wikimedia.org/wikipedia/commons/c/c3/Solar_sys8.jpg',
						'https://upload.wikimedia.org/wikipedia/commons/9/99/PIA03149_-_Sirius_A_and_B_Hubble_photo.jpg',

					]
				};
				var backgroundModes = ['Ice Giants', 'Rocky Planets', 'Gas Giants', 'Stars and Nebula'];
				var backgroundModeEmojis = {
					'Ice Giants': '❄',
					'Rocky Planets': '⬢',
					'Gas Giants': '◎',
					'Stars and Nebula': '✦'
				};
				var currentBackgroundModeIndex = 0;
				var backgrounds = backgroundSets[backgroundModes[currentBackgroundModeIndex]];
				var backgroundIndex = 0;
				var overlay = 'linear-gradient(rgba(5, 11, 20, 0.35), rgba(5, 11, 20, 0.35))';
				var layerA = document.querySelector('.background-layer-a');
				var layerB = document.querySelector('.background-layer-b');
				var activeLayer = layerA;
				var inactiveLayer = layerB;
				var backgroundSwitcher = document.getElementById('background-switcher');

				function preloadBackgrounds(list) {
					list.forEach(function(url) {
						var img = new Image();
						img.src = url;
					});
				}

				function setLayerBackground(layer, index) {
					if (!layer || !backgrounds || !backgrounds.length) return;
					layer.style.backgroundImage = overlay + ", url('" + backgrounds[index] + "')";
				}

				function transitionToBackground(index) {
					if (!backgrounds || !backgrounds.length) return;
					setLayerBackground(inactiveLayer, index);
					inactiveLayer.classList.add('active');
					activeLayer.classList.remove('active');

					var previousLayer = activeLayer;
					activeLayer = inactiveLayer;
					inactiveLayer = previousLayer;
				}

				function syncBackgroundButton() {
					if (backgroundSwitcher) {
						var currentMode = backgroundModes[currentBackgroundModeIndex];
						var emoji = backgroundSwitcher.querySelector('.theme-emoji');
						if (emoji) {
							emoji.textContent = backgroundModeEmojis[currentMode] || '⭐';
						}
						backgroundSwitcher.setAttribute('aria-label', currentMode);
						backgroundSwitcher.setAttribute('title', currentMode);
					}
				}

				function applyBackgroundMode(modeIndex) {
					currentBackgroundModeIndex = modeIndex;
					backgrounds = backgroundSets[backgroundModes[currentBackgroundModeIndex]];
					backgroundIndex = 0;
					preloadBackgrounds(backgrounds);
					transitionToBackground(backgroundIndex);
					syncBackgroundButton();
				}

				backgroundModes.forEach(function(mode) {
					preloadBackgrounds(backgroundSets[mode]);
				});

				if (backgroundSwitcher) {
					backgroundSwitcher.addEventListener('click', function() {
						var nextModeIndex = (currentBackgroundModeIndex + 1) % backgroundModes.length;
						applyBackgroundMode(nextModeIndex);
					});
				}

				applyBackgroundMode(currentBackgroundModeIndex);
				setInterval(function() {
					backgroundIndex = (backgroundIndex + 1) % backgrounds.length;
					transitionToBackground(backgroundIndex);
				}, 30000);
			});
		</script>
