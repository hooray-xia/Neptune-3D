		<script>
			function showContent() {
				document.getElementById('intro').style.display = 'none';
				document.getElementById('main-content').style.display = 'block';
			}

			window.addEventListener('DOMContentLoaded', function() {
				var memberItems = document.querySelectorAll('.member-grid li');
				memberItems.forEach(function(item) {
					var card = item.querySelector('.member-main');
					if (!card) return;
					var bio = card.querySelector('.member-bio');
					if (bio) {
						var bioText = bio.textContent.replace(/\u00a0/g, '').trim();
						if (!bioText) {
							bio.remove();
						} else {
							var rank = item.querySelector('.member-rank');
							if (rank && bio.parentElement === card) {
								item.insertBefore(bio, rank.nextSibling);
							}
						}
					}
				});

				var memberGrid = document.getElementById('member-grid');
				var memberSort = document.getElementById('member-sort');
				if (memberGrid && memberSort) {
					var originalMemberItems = Array.prototype.slice.call(memberGrid.querySelectorAll('li'));
					var originalOrder = new Map();

					originalMemberItems.forEach(function(item, index) {
						originalOrder.set(item, index);
					});

					function normalizeSortText(value) {
						return (value || '')
							.toLowerCase()
							.normalize('NFD')
							.replace(/[\u0300-\u036f]/g, '');
					}

					function getMemberName(item) {
						var link = item.querySelector('.member-name');
						return link ? link.textContent.trim() : '';
					}

					function getMemberRank(item) {
						var rank = item.querySelector('.member-rank');
						return rank ? rank.textContent.trim() : '';
					}

					function getRankParts(rankText) {
						var parts = (rankText || '').split(',');
						var secondaryParts = parts.slice(1).map(function(part) {
							return normalizeSortText(part);
						}).filter(function(part) {
							return part.length > 0;
						});
						return {
							primary: normalizeSortText(parts[0] || ''),
							secondary: normalizeSortText(parts.slice(1).join(',') || ''),
							secondaryParts: secondaryParts
						};
					}

					function getCodingLevelOrder(rankText) {
						var primary = getRankParts(rankText).primary;
						if (primary.indexOf('proto-omicronner') !== -1) return 70;
						if (primary.indexOf('omicron') !== -1 || primary.indexOf('omnicron') !== -1) return 60;
						if (primary.indexOf('sigma-deltagrammer') !== -1) return 50;
						if (primary.indexOf('pro-deltagrammer') !== -1) return 40;
						if (primary.indexOf('deltagrammer') !== -1) return 30;
						if (primary.indexOf('pro-alpha coder') !== -1) return 20;
						if (primary.indexOf('alpha coder') !== -1) return 10;
						return 0;
					}

					function hasRecognizedRank(rankText) {
						return getCodingLevelOrder(rankText) > 0 || getStaffRankOrder(rankText) > 0;
					}

					function secondaryHas(rankText, variants) {
						var parts = getRankParts(rankText).secondaryParts;
						return variants.some(function(variant) {
							return parts.some(function(part) {
								return part.indexOf(variant) !== -1;
							});
						});
					}

					function getStaffRankOrder(rankText) {
						var secondary = getRankParts(rankText).secondary;
						if (secondary.indexOf('omega prime') !== -1) return 120;
						if (secondaryHas(rankText, ['admin']) && !secondaryHas(rankText, ['pro-admin'])) return 110;
						if (secondaryHas(rankText, ['pro-admin'])) return 100;
						if (secondaryHas(rankText, ['leader/head', 'brainstormer leader', 'brainstormer head', 'head brainstormer', 'processingjs leader', 'processing js leader', 'proccesingjs leader', 'proccesing js leader', 'pjs head', 'Art Corona', 'art corona', 'Project Inspector', 'project inspector'])) return 90;
						if (secondaryHas(rankText, ['co-leader', 'co-processing js leader', 'co pjs leader', 'processingjs co-leader', 'processing js co-leader', 'proccesingjs co-leader', 'proccesing js co-leader', 'html builder', 'HTML Builder', 'Animation Origo', 'animation origo'])) return 80;
						return 0;
					}

					function getRoleOrder(rankText) {
						var secondary = getRankParts(rankText).secondary;
						if (secondary.indexOf('python developer') !== -1) return 60;
						if (secondary.indexOf('developer') !== -1) return 55;
						if (secondary.indexOf('animator') !== -1) return 50;
						if (secondary.indexOf('brainstormer') !== -1) return 45;
						if (secondary.indexOf('artist') !== -1) return 40;
						if (secondary.indexOf('helper') !== -1) return 30;
						return 0;
					}

					function getRankOrder(rankText) {
						if (!hasRecognizedRank(rankText)) {
							return -1;
						}
						var staffOrder = getStaffRankOrder(rankText);
						var roleOrder = getRoleOrder(rankText);
						var codingLevelOrder = getCodingLevelOrder(rankText);
						if (staffOrder) {
							return 2000000 + staffOrder * 10000 + codingLevelOrder * 100 + roleOrder;
						}
						return codingLevelOrder * 100 + roleOrder;
					}

					function compareDefault(a, b) {
						return originalOrder.get(a) - originalOrder.get(b);
					}

					function sortMembers() {
						var mode = memberSort.value;
						var items = originalMemberItems.slice();

						items.sort(function(a, b) {
							var nameA = normalizeSortText(getMemberName(a));
							var nameB = normalizeSortText(getMemberName(b));
							var rankA = getMemberRank(a);
							var rankB = getMemberRank(b);

							if (mode === 'alphabetical') {
								return nameA.localeCompare(nameB) || compareDefault(a, b);
							}

							if (mode === 'level') {
								var hasRankA = hasRecognizedRank(rankA);
								var hasRankB = hasRecognizedRank(rankB);
								if (hasRankA !== hasRankB) {
									return hasRankB - hasRankA;
								}
								return getCodingLevelOrder(rankB) - getCodingLevelOrder(rankA) ||
									getRoleOrder(rankB) - getRoleOrder(rankA) ||
									nameA.localeCompare(nameB) ||
									compareDefault(a, b);
							}

							if (mode === 'rank') {
								return getRankOrder(rankB) - getRankOrder(rankA) ||
									getRoleOrder(rankB) - getRoleOrder(rankA) ||
									getCodingLevelOrder(rankB) - getCodingLevelOrder(rankA) ||
									nameA.localeCompare(nameB) ||
									compareDefault(a, b);
							}

							return compareDefault(a, b);
						});

						items.forEach(function(item) {
							memberGrid.appendChild(item);
						});
					}

					memberSort.addEventListener('change', sortMembers);
					sortMembers();
				}

				var backgroundSets = {
					'Ice Giants': [
