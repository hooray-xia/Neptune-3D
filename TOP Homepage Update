			list-style: none;
		}

		.member-grid li {
			display: grid;
			grid-template-columns: 64px minmax(0, 1fr) auto;
			grid-template-areas:
				"avatar main rank"
				"avatar bio bio";
			align-items: center;
			column-gap: 16px;
			row-gap: 0;
			text-align: left;
			min-height: 108px;
			margin: 0;
			padding: 18px 20px;
			background: rgba(0, 20, 50, 0.6);
			border-radius: 12px;
			transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
			position: relative;
			overflow: hidden;
			z-index: 1;
			border: none;
		}

		.member-grid li::before {
			content: '';
			position: absolute;
			inset: -140px;
			background: conic-gradient(transparent, transparent, transparent, rgba(0, 240, 255, 1));
			animation: rotate-border 4s linear infinite;
			animation-play-state: paused;
			opacity: 0;
			transition: opacity 0.3s ease;
			z-index: -2;
		}

		.member-grid li::after {
			content: '';
			position: absolute;
			inset: 2px;
			background: rgba(0, 20, 50, 0.9);
			border-radius: 10px;
			z-index: -1;
		}

